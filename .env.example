TOKEN=your_bot_token_here
CLIENT_ID=your_client_id_here
DB_PATH=./database.sqlite
PREFIX=!
EMBED_COLOR=#111111
LOG_LEVEL=info

# Groq AI API key (free: https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# Memory / history
AI_MAX_HISTORY=20
AI_ENABLED=true

# Spotify API (free: https://developer.spotify.com/dashboard)
# Needed for Spotify track support in /play
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
